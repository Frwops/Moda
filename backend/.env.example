# Local MySQL or MariaDB — create DB_NAME and user before starting the API.
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=moda
DB_PASSWORD=moda
DB_NAME=moda

# Never enable in production. Use TypeORM migrations instead.
TYPEORM_SYNC=false

# JWT signing (use long random strings in real env, min ~32 chars)
JWT_ACCESS_SECRET=change-me-use-openssl-rand-hex-32-or-longer-secret

# Google Sign-In — Web client ID from Google Cloud Console (OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=
